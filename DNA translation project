            <textarea id="mrna-input-field" class="seq-textarea font-mono" placeholder="Enter mRNA Sequence (A, U, C, G)..."></textarea>
            <span class="input-error" id="mrna-input-error"></span>
          </div>
          
          <div class="settings-grid">
            <div class="setting-item">
              <label for="translate-mode-select">Coupled Mode:</label>
              <select id="translate-mode-select" class="styled-select">
                <option value="decoupled">Decoupled (Eukaryotic - Standalone)</option>
                <option value="coupled">Coupled (Prokaryotic - Simulataneous Trans/Trans)</option>
              </select>
            </div>
            
            <div class="setting-item">
              <label for="translate-speed-slider">Speed (codons/sec):</label>
              <input type="range" id="translate-speed-slider" min="1" max="5" value="2">
