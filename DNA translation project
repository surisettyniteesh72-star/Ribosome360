:root {
  /* Color Palette */
  --bg-color: #070b13;
  --surface-color: rgba(17, 24, 39, 0.75);
  --border-color: rgba(255, 255, 255, 0.08);
  --border-active: rgba(255, 255, 255, 0.2);
  
  --text-main: #f3f4f6;
  --text-heading: #f9fafb;
  --text-muted: #9ca3af;
  
  /* Glowing Accent Colors */
  --color-dna: #6366f1; /* Indigo */
  --color-rna: #06b6d4; /* Cyan */
  --color-protein: #10b981; /* Emerald */
  
  --color-success: #10b981;
  --color-warning: #f59e0b;
  --color-danger: #f43f5e;
  --color-info: #3b82f6;

  /* Nucleotide Bases Colors */
  --base-a: #22d3ee; /* Cyan */
  --base-t: #f59e0b; /* Amber */
  --base-u: #ff7e5f; /* Coral */
  --base-c: #3b82f6; /* Blue */
  --base-g: #a855f7; /* Purple */
}

/* Reset & Scrollbar */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background-color: var(--bg-color);
  background-image: 
    radial-gradient(at 10% 20%, rgba(99, 102, 241, 0.05) 0px, transparent 50%),
    radial-gradient(at 90% 80%, rgba(6, 182, 212, 0.04) 0px, transparent 50%);
  color: var(--text-main);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  line-height: 1.6;
  overflow-x: hidden;
}

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}
::-webkit-scrollbar-track {
  background: var(--bg-color);
}
::-webkit-scrollbar-thumb {
  background: #1f2937;
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: #374151;
}

/* Typography Helpers */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Outfit', sans-serif;
  color: var(--text-heading);
  font-weight: 700;
  letter-spacing: -0.02em;
}

.font-mono {
  font-family: 'Fira Code', monospace;
}

/* App Header Styling */
.app-header {
  background: rgba(7, 11, 19, 0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 10px 0;
}

.header-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.app-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
}

.logo-icon {
  background: linear-gradient(135deg, var(--color-dna), var(--color-rna));
  width: 42px;
  height: 42px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
}

.logo-icon i {
  color: #fff;
  font-size: 20px;
}

.logo-spin {
  animation: dna-rotate 8s linear infinite;
}

.logo-text h1 {
  font-size: 20px;
  font-weight: 800;
}

.logo-text h1 span {
  background: linear-gradient(to right, var(--color-rna), var(--color-protein));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.logo-text p {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 500;
}

/* Navigation Menu */
.app-nav {
  flex-grow: 1;
  max-width: 800px;
}

.nav-links {
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.nav-btn {
  background: transparent;
  border: 1px solid transparent;
  color: var(--text-muted);
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 13.5px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.nav-btn i {
  font-size: 14px;
}

.nav-btn:hover {
  background: rgba(255, 255, 255, 0.03);
  color: var(--text-heading);
}

.nav-btn.active {
  background: rgba(99, 102, 241, 0.1);
  border-color: rgba(99, 102, 241, 0.25);
  color: #818cf8;
  box-shadow: 0 0 10px rgba(99, 102, 241, 0.1);
}

/* Preset Dropdown */
.preset-selector-container {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--text-muted);
}

.preset-select {
  background: #111827;
  border: 1px solid var(--border-color);
  color: var(--text-heading);
  padding: 8px 12px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  outline: none;
  transition: all 0.3s;
}

.preset-select:focus {
  border-color: var(--color-dna);
  box-shadow: 0 0 8px rgba(99, 102, 241, 0.2);
}

/* Self-Test Banner */
.test-banner {
  background: rgba(16, 185, 129, 0.15);
  border-bottom: 1px solid rgba(16, 185, 129, 0.3);
  padding: 8px 0;
  color: #34d399;
  font-size: 13px;
  font-weight: 600;
  transition: all 0.5s;
}

.test-banner-content {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.test-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'Outfit', sans-serif;
  letter-spacing: 0.05em;
  background: rgba(16, 185, 129, 0.2);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 11px;
}

.close-banner {
  background: transparent;
  border: none;
  color: #34d399;
  font-size: 18px;
  cursor: pointer;
  line-height: 1;
}

.hidden {
  display: none !important;
}

/* Main Container Layout */
.app-main-content {
  max-width: 1400px;
  width: 100%;
  margin: 0 auto;
  padding: 30px 24px;
  flex-grow: 1;
}

.tab-pane {
  display: none;
  animation: fadeIn 0.4s ease-out;
}

.tab-pane.active {
  display: block;
}

/* ================= LEARN TAB ARTICLE DESIGN ================= */
.article-layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 30px;
  align-items: start;
}

.scitable-article {
  background: var(--surface-color);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  padding: 35px;
}

.article-hero {
  margin-bottom: 25px;
}

.article-category {
  color: var(--color-rna);
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: inline-block;
  margin-bottom: 8px;
}

.article-title {
  font-size: 32px;
  margin-bottom: 15px;
  background: linear-gradient(135deg, #fff 40%, var(--text-muted));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  background: rgba(255, 255, 255, 0.02);
  padding: 12px 16px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.04);
}

.author-avatar {
  background: rgba(99, 102, 241, 0.2);
  color: #a5b4fc;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

.author-info p {
  margin: 0;
}

.author-name {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-heading);
}

.citation-detail {
  font-size: 11px;
  color: var(--text-muted);
}

.article-body h2 {
  font-size: 20px;
  margin-top: 30px;
  margin-bottom: 15px;
  border-left: 3px solid var(--color-dna);
  padding-left: 12px;
}

.article-body p {
  color: #d1d5db;
  font-size: 15.5px;
  margin-bottom: 20px;
}

.lead-paragraph {
  font-size: 17px !important;
  color: #e5e7eb !important;
  font-weight: 500;
  border-left: none !important;
}

.article-divider {
  height: 1px;
  background: linear-gradient(to right, rgba(255, 255, 255, 0.1), transparent);
  margin: 25px 0;
}

/* Interactive Card in Article */
.interactive-card {
  background: rgba(7, 11, 19, 0.6);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 20px;
  margin: 25px 0;
  transition: all 0.3s;
}

.interactive-card:hover {
  border-color: rgba(99, 102, 241, 0.2);
}

.interactive-card h3 {
  font-size: 15px;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  color: var(--text-heading);
}

.dogma-flow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 10px 0;
}

.dogma-node {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.02);
  padding: 15px 10px;
  border-radius: 10px;
  border: 1px solid rgba(255, 255, 255, 0.04);
}

.node-icon {
  font-size: 20px;
  margin-bottom: 8px;
}

.dna-node .node-icon { color: var(--color-dna); }
.rna-node .node-icon { color: var(--color-rna); }
.protein-node .node-icon { color: var(--color-protein); }

.node-title {
  display: block;
  font-weight: 700;
  font-family: 'Outfit', sans-serif;
  font-size: 14px;
}

.node-desc {
  font-size: 10px;
  color: var(--text-muted);
}

.dogma-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: rgba(255, 255, 255, 0.15);
  font-size: 14px;
}

.arrow-label {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: 4px;
}

.coupled-note-card {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.05) 0%, rgba(6, 182, 212, 0.02) 100%);
  border: 1px solid rgba(99, 102, 241, 0.15);
  border-radius: 12px;
  padding: 20px;
  margin: 25px 0;
}

.coupled-note-card h4 {
  font-size: 15px;
  margin-bottom: 12px;
  color: #a5b4fc;
}

.split-comparison {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.split-comparison h5 {
  font-size: 13px;
  margin-bottom: 6px;
  color: var(--text-heading);
}

.split-comparison p {
  font-size: 12.5px !important;
  color: var(--text-muted) !important;
  margin-bottom: 0 !important;
}

.border-left {
  border-left: 1px dashed rgba(255, 255, 255, 0.1);
  padding-left: 20px;
}

.article-cta-box {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid var(--border-color);
  padding: 24px;
  border-radius: 12px;
  margin-top: 35px;
  text-align: center;
}

.article-cta-box h4 {
  font-size: 16px;
  margin-bottom: 8px;
}

.article-cta-box p {
  font-size: 13.5px !important;
  color: var(--text-muted) !important;
  margin-bottom: 20px !important;
}

.cta-buttons {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15px;
}

.cta-btn {
  padding: 10px 18px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  gap: 6px;
}

.primary-cta {
  background: var(--color-dna);
  color: #fff;
}
.primary-cta:hover {
  background: #4f46e5;
  box-shadow: 0 0 12px rgba(99, 102, 241, 0.3);
}

.secondary-cta {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-color);
  color: var(--text-heading);
}
.secondary-cta:hover {
  background: rgba(255, 255, 255, 0.08);
}

/* Sidebar Styling */
.article-sidebar {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.sidebar-widget {
  background: var(--surface-color);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  padding: 24px;
}

.sidebar-widget h3 {
  font-size: 15px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.sidebar-widget p {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.highlight-list {
  list-style: none;
}

.highlight-list li {
  font-size: 12px;
  margin-bottom: 10px;
  padding-left: 14px;
  position: relative;
  color: #d1d5db;
}

.highlight-list li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 6px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-rna);
}

/* Stats Widget */
.stat-grid-mini {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.stat-box-mini {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.04);
  padding: 10px;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
}

.stat-box-mini .lbl {
  font-size: 9.5px;
  color: var(--text-muted);
  font-weight: 700;
  text-transform: uppercase;
}

.stat-box-mini .val {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-heading);
  margin-top: 4px;
}

/* ================= SIMULATION LAYOUT ================= */
.simulation-layout {
  display: grid;
  grid-template-columns: 360px 1fr;
  gap: 25px;
  align-items: start;
}

.sim-controls-panel {
  background: var(--surface-color);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  padding: 24px;
}

.sim-controls-panel h2 {
  font-size: 18px;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.control-group {
  margin-bottom: 18px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.control-group label {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--text-muted);
}

.seq-textarea {
  background: #090e18;
  border: 1px solid var(--border-color);
  color: var(--text-heading);
  border-radius: 10px;
  padding: 12px;
  font-size: 13px;
  height: 90px;
  resize: none;
  outline: none;
  width: 100%;
  letter-spacing: 0.05em;
  transition: all 0.3s;
}

.seq-textarea:focus {
  border-color: rgba(99, 102, 241, 0.3);
  box-shadow: 0 0 10px rgba(99, 102, 241, 0.15);
}

.input-error {
  font-size: 11px;
  color: var(--color-danger);
  font-weight: 500;
}

.settings-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 15px;
  margin-bottom: 20px;
}

.setting-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.setting-item label {
  font-size: 11.5px;
  font-weight: 600;
  color: var(--text-muted);
}

.styled-select {
  background: #090e18;
  border: 1px solid var(--border-color);
  color: var(--text-heading);
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 12.5px;
  font-weight: 600;
  cursor: pointer;
}

.styled-select:focus {
  border-color: var(--color-rna);
}

/* Speed slider */
.setting-item input[type="range"] {
  accent-color: var(--color-rna);
  cursor: pointer;
}

.slider-val {
  font-size: 11px;
  font-weight: 700;
  color: var(--color-rna);
  align-self: flex-end;
}

/* Simulation Controls Buttons */
.action-buttons-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 20px;
}

.btn {
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.btn-primary {
  background: var(--color-dna);
  color: #fff;
  border: none;
}
.btn-primary:hover {
  background: #4f46e5;
  box-shadow: 0 0 10px rgba(99, 102, 241, 0.25);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid var(--border-color);
  color: var(--text-heading);
}
.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.08);
}
.btn-secondary:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.btn-danger {
  background: rgba(244, 63, 94, 0.1);
  border: 1px solid rgba(244, 63, 94, 0.2);
  color: var(--color-danger);
}
.btn-danger:hover {
  background: rgba(244, 63, 94, 0.15);
}

.btn-xs-link {
  background: transparent;
  border: none;
  color: #818cf8;
  padding: 0;
  cursor: pointer;
  font-size: 11px;
}

.btn-xs-link:hover {
  color: #a5b4fc;
}

/* Status Card */
.status-card {
  background: rgba(7, 11, 19, 0.4);
  border: 1px solid var(--border-color);
  border-radius: 10px;
  padding: 14px;
}

.status-card h3 {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.status-card p {
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 12px;
}

.progress-bar-container {
  background: rgba(255, 255, 255, 0.05);
  height: 6px;
  border-radius: 3px;
  overflow: hidden;
}

.progress-bar {
  background: linear-gradient(to right, var(--color-rna), var(--color-protein));
  height: 100%;
  border-radius: 3px;
  transition: width 0.3s ease;
}

.progress-bar-container.mini-bar {
  height: 4px;
}

/* Visualizer Panels */
.sim-visualizer-panel {
  background: var(--surface-color);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  padding: 24px;
  display: flex;
  flex-direction: column;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.panel-header h3 {
  font-size: 16px;
}

.badge {
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 20px;
}

.info-badge {
  background: rgba(6, 182, 212, 0.1);
  color: #22d3ee;
  border: 1px solid rgba(6, 182, 212, 0.2);
}

.visualizer-container {
  background: #070b13;
  border: 1px solid var(--border-color);
  border-radius: 12px;
  overflow: hidden;
  height: 320px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.8);
}

.legend-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15px;
  margin-top: 15px;
  flex-wrap: wrap;
}

.legend-item {
  font-size: 11px;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 6px;
  font-weight: 600;
}

.legend-color {
  width: 10px;
  height: 10px;
  border-radius: 3px;
  display: inline-block;
}

.base-a { background-color: var(--base-a); }
.base-t { background-color: var(--base-t); }
.base-u { background-color: var(--base-u); }
.base-c { background-color: var(--base-c); }
.base-g { background-color: var(--base-g); }

/* Peptide chain display */
.pep-chain-display {
  margin-top: 20px;
  border-top: 1px solid var(--border-color);
  padding-top: 15px;
}

.pep-chain-display h4 {
  font-size: 13.5px;
  color: var(--text-muted);
  margin-bottom: 10px;
}

.pep-list {
  display: flex;
  align-items: center;
  gap: 8px;
  overflow-x: auto;
  padding: 10px 0;
}

.pep-empty {
  font-size: 12.5px;
  color: var(--text-muted);
  font-style: italic;
}

.pep-bead {
  background: rgba(16, 185, 129, 0.1);
  border: 1px solid rgba(16, 185, 129, 0.3);
  color: #34d399;
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 6px;
  animation: scale-up-bead 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  white-space: nowrap;
}

.pep-link {
  color: rgba(255, 255, 255, 0.15);
  font-size: 11px;
}

/* ================= MUTATION SANDBOX ================= */
.mutation-sandbox-container {
  background: var(--surface-color);
  backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  padding: 30px;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.sandbox-header h2 {
  font-size: 22px;
  margin-bottom: 6px;
}

.sandbox-header p {
  font-size: 13.5px;
  color: var(--text-muted);
}

.sequence-editors-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.seq-editor-box {
  background: rgba(7, 11, 19, 0.4);
  border-radius: 12px;
  padding: 20px;
  border-width: 1px;
  border-style: solid;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.wt-border { border-color: rgba(99, 102, 241, 0.15); }
.mut-border { border-color: rgba(244, 63, 94, 0.15); }

.box-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.box-title h3 {
  font-size: 14.5px;
}

.tag {
  font-size: 9.5px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 4px;
  text-transform: uppercase;
}

.wt-tag { background: rgba(99, 102, 241, 0.2); color: #818cf8; }
.mut-tag { background: rgba(244, 63, 94, 0.2); color: #fb7185; }

.seq-helper-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 11.5px;
  color: var(--text-muted);
}

/* Mutation Consequence Card */
.mutation-analysis-card {
  background: rgba(7, 11, 19, 0.3);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  overflow: hidden;
}

.mutation-analysis-card .card-header {
  background: rgba(255, 255, 255, 0.02);
  border-bottom: 1px solid var(--border-color);
  padding: 16px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mutation-analysis-card .card-header h3 {
  font-size: 15px;
}

.mutation-badge {
  font-size: 10px;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 6px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.mutation-badge.info { background: rgba(59, 130, 246, 0.15); color: #60a5fa; }
.mutation-badge.success { background: rgba(16, 185, 129, 0.15); color: #34d399; }
.mutation-badge.warning { background: rgba(245, 158, 11, 0.15); color: #fbbf24; }
.mutation-badge.danger { background: rgba(244, 63, 94, 0.15); color: #f87171; }

.mutation-analysis-card .card-body {
  padding: 20px;
}

.impact-text-block {
  margin-bottom: 20px;
}

.impact-title {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--text-muted);
}

.impact-text-block h4 {
  font-size: 15px;
  color: var(--text-heading);
  margin-top: 4px;
}

/* Codon Grid Alignments */
.codon-alignment-viewer {
  display: flex;
  flex-direction: column;
  gap: 12px;
  background: #090e18;
  padding: 16px;
  border-radius: 8px;
  overflow-x: auto;
  border: 1px solid var(--border-color);
}

.alignment-header {
  font-size: 11.5px;
  font-weight: 700;
  color: var(--text-muted);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  padding-bottom: 6px;
}

.alignment-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.row-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-muted);
  width: 90px;
  min-width: 90px;
}

.codon-seq {
  display: flex;
